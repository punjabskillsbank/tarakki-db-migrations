<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.8.xsd">

    <changeSet id="TK_2_Create_Boards_Table" author="Gurwinder Singh">
        <!-- Halt script if the table already exists -->
        <preConditions onFail="MARK_RAN">
            <not>
                <tableExists tableName="boards"/>
            </not>
        </preConditions>

        <createTable tableName="boards" >
            <column name="boards_id" type="BIGINT">
                <constraints primaryKey="true" primaryKeyName="pk_boards" nullable="false"/>
            </column>

            <column name="boards_name" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>

            <column name="board_type" type="VARCHAR(50)">
                <constraints nullable="false"/>
            </column>

            <column name="description" type="TEXT"/>

            <column name="created_by" type="BIGINT" >
                <constraints nullable="false"/>
            </column>


            <column name="updated_by" type="TIMESTAMP" >
                <constraints nullable="false"/>
            </column>

        </createTable>

        <!-- Rollback: Drop the table if it exists -->
        <rollback>
            <dropTable tableName="boards"/>
        </rollback>
    </changeSet>

</databaseChangeLog>
