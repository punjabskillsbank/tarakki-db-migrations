<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.8.xsd">

    <changeSet id="TK_22_Create_Tasks_Table" author="Dhruvjot_Singh">

        <preConditions onFail="MARK_RAN">
            <not>
                <tableExists tableName="tasks"/>
            </not>
        </preConditions>

        <createTable tableName="tasks">

            <column name="task_id" type="BIGSERIAL">
                <constraints primaryKey="true" nullable="false"/>
            </column>

            <column name="board_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>

            <column name="group_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>

            <column name="title" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>

            <column name="position" type="INT">
                <constraints nullable="false"/>
            </column>

            <column name="created_by" type="UUID">
                <constraints nullable="false"/>
            </column>

            <column name="created_at" type="TIMESTAMP">
                <constraints nullable="false"/>
            </column>

            <column name="updated_at" type="TIMESTAMP">
                <constraints nullable="false"/>
            </column>

        </createTable>

        

        <addForeignKeyConstraint
                baseTableName="tasks"
                baseColumnNames="board_id"
                constraintName="fk_tasks_board_id"
                referencedTableName="boards"
                referencedColumnNames="board_id"
                onDelete="CASCADE"/>

        <addForeignKeyConstraint
                baseTableName="tasks"
                baseColumnNames="group_id"
                constraintName="fk_tasks_group_id"
                referencedTableName="groups"
                referencedColumnNames="group_id"
                onDelete="CASCADE"/>

        <addForeignKeyConstraint
                baseTableName="tasks"
                baseColumnNames="created_by"
                constraintName="fk_tasks_created_by"
                referencedTableName="members"
                referencedColumnNames="member_id"
                onDelete="CASCADE"/>

        <rollback>
            <dropTable tableName="tasks"/>
        </rollback>

    </changeSet>

</databaseChangeLog>