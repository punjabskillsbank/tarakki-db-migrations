<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.3.xsd">

    <changeSet id="TK_23_CREATE_COLUMN_TYPE_ENUM" author="ishmeet-codes">

        <sql>
            CREATE TYPE column_type_enum AS ENUM (
                'STRING',
                'INT',
                'DOUBLE',
                'DATE',
                'CHAR'
            );
        </sql>

        <rollback>
            DROP TYPE IF EXISTS column_type_enum;
        </rollback>

    </changeSet>

    <changeSet id="TK_23_CREATE_BOARD_COLUMNS_TABLE" author="your_name">

        <createTable tableName="board_columns">

            <column name="board_column_id" type="BIGSERIAL">
                <constraints primaryKey="true" nullable="false"/>
            </column>

            <column name="board_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>

            <column name="column_name" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>

            <column name="column_type" type="column_type_enum">
                <constraints nullable="false"/>
            </column>

            <column name="position" type="INT">
                <constraints nullable="false"/>
            </column>

            <column name="created_at" type="TIMESTAMP">
                <constraints nullable="false"/>
            </column>

            <column name="updated_at" type="TIMESTAMP"/>

        </createTable>

        <addForeignKeyConstraint
                baseTableName="board_columns"
                baseColumnNames="board_id"
                referencedTableName="boards"
                referencedColumnNames="board_id"
                constraintName="fk_board_columns_board"
                onDelete="CASCADE"/>

        <createIndex indexName="idx_board_columns_board_id"
                     tableName="board_columns">
            <column name="board_id"/>
        </createIndex>

        <rollback>
            <dropTable tableName="board_columns"/>
        </rollback>

    </changeSet>

</databaseChangeLog>