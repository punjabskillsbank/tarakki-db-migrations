<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.8.xsd">


    <changeSet id="TK__Create_Groups_Table" author="Gurwinder Singh">

        <preConditions onFail="MARK_RAN">
            <not>
                <tableExists tableName="groups"/>
            </not>
        </preConditions>
        <createTable tableName="groups">
            <column name="group_id" type="BIGSERIAL">
                <constraints primaryKey="true" primaryKeyName="pk_groups" nullable="false"/>
            </column>
            <column name="group_title" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="fk_board_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="description" type="TEXT"/>

            <column name="created_at" type="TIMESTAMP" >
            </column>
            <column name="updated_at" type="TIMESTAMP">
            </column>
            <column name="is_active" type="BOOLEAN">
                <constraints nullable="false"/>
            </column>
        </createTable>
        <addForeignKeyConstraint
                baseColumnNames="fk_board_id"
                baseTableName="groups"
                constraintName="fk_boards"
                referencedColumnNames="board_id"
                referencedTableName="boards"
                onDelete="CASCADE"/>
        <rollback>
            <dropTable tableName="boards"/>
        </rollback>
    </changeSet>
</databaseChangeLog>
