<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.8.xsd">

    <changeSet id="TK_10_01_Create_Org_Member_Role_Enum" author="Kirandeep Kaur">
        <sql>CREATE TYPE org_member_role_enum AS ENUM('ORG_ADMIN','ORG_MEMBER');</sql>

        <rollback>
            <sql>DROP TYPE IF EXISTS org_member_role;</sql>
        </rollback>
    </changeSet>

    <changeSet id="TK_10_02_Create_Org_Members_Table" author="Kirandeep Kaur">
        <preConditions onFail="MARK_RAN">
            <not>
                <tableExists tableName="org_members"/>
            </not>
        </preConditions>

        <createTable tableName="org_members">
            <column name="org_member_id" type="BIGSERIAL">
                <constraints primaryKey="true" nullable="false"/>
            </column>

            <column name="org_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>

            <column name="member_id" type="UUID">
                <constraints nullable="false"/>
            </column>

            <column name="org_member_role" type="org_member_role_enum">
                <constraints nullable="false"/>
            </column>

            <column name="created_at" type="TIMESTAMP" >
                <constraints nullable="false"/>
            </column>

            <column name="updated_at" type="TIMESTAMP" >
                <constraints nullable="false"/>
            </column>
        </createTable>

        <addUniqueConstraint
                tableName="org_members"
                columnNames="org_id, member_id"
                constraintName="uk_org_members_org_id_member_id"/>

        <addForeignKeyConstraint
                baseTableName="org_members"
                baseColumnNames="org_id"
                constraintName="fk_org_members_org_id"
                referencedTableName="organizations"
                referencedColumnNames="org_id"
                onDelete="CASCADE"/>

        <addForeignKeyConstraint
                baseTableName="org_members"
                baseColumnNames="member_id"
                constraintName="fk_org_members_member_id"
                referencedTableName="members"
                referencedColumnNames="member_id"
                onDelete="CASCADE"/>

        <rollback>
            <dropTable tableName="org_members"/>
        </rollback>
    </changeSet>
</databaseChangeLog>