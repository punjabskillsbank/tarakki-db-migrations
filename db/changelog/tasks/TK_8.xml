<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.8.xsd">
    <changeSet id="TK_8_Create_Tasks_Table" author="Gurwinder Singh">
                <preConditions onFail="MARK_RAN" >
                   <not>
                       <tableExists tableName="tasks"/>
                   </not>
               </preConditions>
    <createTable tableName="tasks">
        <column name="task_id" type="BIGSERIAL">
            <constraints primaryKey="true" primaryKeyName="pk_tasks" nullable="false"/>
        </column>
        <column name="task" type="VARCHAR(250)">
            <constraints nullable="false"/>
        </column>
        <column name="group_id" type="BIGINT">
            <constraints nullable="false"/>
        </column>
        <column name="owner" type="VARCHAR(50)">
            <constraints nullable="false"/>
        </column>
        <column name="status" type="VARCHAR(50)"/>
        <column name="priority" type="VARCHAR(50)"/>
        <column name="timeline" type="TIMESTAMP"/>
    </createTable>
        <addForeignKeyConstraint
                baseTableName="tasks"
                baseColumnNames="group_id"
                referencedTableName="groups"
                referencedColumnNames="group_id"
                constraintName="fk_groups"
                onDelete="CASCADE"/>
    </changeSet>
    </databaseChangeLog>