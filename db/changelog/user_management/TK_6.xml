<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.8.xsd">

    <changeSet id="TK_6_01_Create_Members_Table" author="Kirandeep Kaur">
         <preConditions onFail="MARK_RAN">
            <not>
                <tableExists tableName="Members"/>
            </not>
         </preConditions>

        <createTable tableName="members">
             <column name="member_id" type="UUID">
                  <constraints primaryKey="true" nullable="false"/>
             </column>

             <column name="first_name" type="VARCHAR(100)"/>
             <column name="last_name" type="VARCHAR(100)"/>

             <column name="email" type="VARCHAR(255)">
                 <constraints nullable="false" unique="true"/>
             </column>

             <column name="profile_photo_s3_key" type="TEXT"/>
             <column name="account_status" type="VARCHAR(20)"/>
             <column name="created_at" type="TIMESTAMP"/>
             <column name="updated_at" type="TIMESTAMP"/>
        </createTable>

        <rollback>
            <dropTable tableName="members"/>
        </rollback>
    </changeSet>
</databaseChangeLog>