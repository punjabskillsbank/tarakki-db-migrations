<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                            http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.8.xsd">

    <changeSet id="TK_2_Add-workspace-table" author="Gaganpreet singh">
        <preConditions onFail="MARK_RAN">
            <not>
                <tableExists tableName="workspaces"/>
            </not>
        </preConditions>

        <sql>CREATE TYPE user_workspace_role AS ENUM('OWNER','EDITOR','VIEWER');</sql>

        <createTable tableName="workspaces">
            <column name="workspace_id" type="BIGSERIAL">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="workspace_name" type="VARCHAR(255)">
                <constraints nullable="false"/>
            </column>
            <column name="user_workspace_role" type="user_workspace_role">
                <constraints nullable="false"/>
            </column>
            <column name="description" type="TEXT"/>
            <column name="created_by" type="UUID">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="TIMESTAMP"/>
            <column name="updated_at" type="TIMESTAMP"/>
        </createTable>

        <rollback>
            <dropTable tableName="workspaces"/>
            <sql>DROP TYPE IF EXISTS user_workspace_role;</sql>
        </rollback>
    </changeSet>
</databaseChangeLog>